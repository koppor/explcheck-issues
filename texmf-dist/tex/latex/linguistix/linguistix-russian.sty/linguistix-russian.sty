\ProvidesExplPackage{linguistix-russian}
                    {2026-05-15}
                    {v1.0}
                    {Русский (Russian)}

\babelprovide [ onchar   = { ids~ fonts } ] { russian }

\addto { \extrasrussian } {
  \cs_if_eq:NNT \@onlypreamble \@notprerr {
    \lngx_set_keys:n {
      old~ style~ numbers    = { false }
    }
  }
  \socket_use:n { lngx / native-numbering }
  \cs_set:Npn \theenumii {
    \localecounter { lower.full } { enumii }
  }
  \cs_set:Npn \theenumiii {
    \localecounter { upper.full } { enumiii }
  }
  \cs_set:Npn \theenumiv { \roman { enumiv } }
  \IfPackageLoadedT { expex } {
    \definelabeltype { Русский } {
      labelgen                 = { list },
      labellist                = {
        а, б, в, г, д, е, ж, з, и, к, л, м, н, о, п,
        р, с, т, у, ф, х, ц, ч, ш, щ, э, ю, я
      },
      labelformat              = {A.},
      fullrefformat            = {XA},
      labelalign               = {left},
      labelwidth               = {1.5em}
    }
    \lingset {
      labeltype                = { Русский }
    }
  }
}
