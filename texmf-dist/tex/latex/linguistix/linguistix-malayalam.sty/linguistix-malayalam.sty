  \clist_map_inline:nn {
    upright,
    italic,
    slanted,
    swash,
    small~ caps
  } {
    \lngx_set_keys:n {
      text~ #1               = { RIT-Rachana-Regular.ttf },
      text~ bold~ #1         = { RIT-Rachana-Bold.ttf },
      text~ sans~ #1         = { RIT-MeeraNew.ttf },
