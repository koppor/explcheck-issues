  \else
    \begin{beamercolorbox}[left,#1]{institute}
      \usebeamerfont{institute}\strut\insertinstitute\par
    \end{beamercolorbox}
  \fi
}

\defbeamertemplate{date}{RWTH}[1][]{%
  \ifx\insertdate\@empty
  \else
