\cs_new:Nn \__ptxcd_title_layout:nn {
  \ifbeamer@inframe
    \vskip-\beamer@frametopskip
    \ifbeamer@plainframe
      \vskip-2.6pt
    \else
      \vskip-\dimexpr3mm-3pt\relax% headheight
    \fi
  \fi
  \nointerlineskip
  \vbox_to_ht:nn {\ifbeamer@plainframe\paperheight\else\textheight\fi}
  {
    \vfill
    \vbox_to_ht:nn {.4\textheight} {
      \vfill
      #1
    }
    \par
    \bool_if:NT \g__ptxcd_titlesepline_bool {\usebeamercolor{separation~line}
      \color{fg}
      \rule{\linewidth}{.25pt}\par}
    \vskip.5ex\par
    \vbox_to_ht:nn {.4\textheight} {
      #2
      \vfill
    }
    \vfill
    \ifbeamer@plainframe
      \makebox[\linewidth][r]{\insertlogo\skip_horizontal:n {-\c__ptxcd_logo_hsep_dim}}
      \vskip-2.6pt
    \fi
  }
}

\cs_new:Nn \__ptxcd_title_layout_graphics:nn {
  \vskip-\beamer@frametopskip
  \nointerlineskip
  \__ptxcd_set_dim_to_ratio:NVN \l__ptxcd_titlegraphic_ht_dim
  \l__ptxcd_titlegraphic_ratio_str \paperheight
  \dim_set:Nn \l__ptxcd_titlegraphic_wd_dim {\paperwidth}
  \vbox_to_ht:nn {\paperheight}{
    #1
    \par\vskip.7\baselineskip\relax
    #2
    \par\vfill
  }
  \smash{\makebox[\linewidth][r]{\raisebox{.36\c__ptxcd_logo_height_dim}{\insertlogo}\skip_horizontal:n {-\c__ptxcd_logo_hsep_dim}}}
}

\clist_map_inline:nn {part,section,subsection} {
  \defbeamertemplate*{#1~page}{RWTH}[1][]{
    \__ptxcd_title_layout:nn  {
      \begin{beamercolorbox}[left]{#1~title}
        {\usebeamerfont{#1~name}\usebeamercolor[fg]{#1~name}\use:c {#1name}\space\use:c{insert#1number}}
      \end{beamercolorbox}
    } {
      \begin{beamercolorbox}[left]{#1~title}
        \usebeamerfont{#1~title}
        \vskip.5ex\use:c{insert#1}\par
      \end{beamercolorbox}
    }
  }
  \expandafter\def\csname #1page\endcsname{%
    \ifbeamer@inframe\usebeamertemplate*{#1~page}\else\frame[plain]{\usebeamertemplate*{#1~page}}\fi
  }
}
