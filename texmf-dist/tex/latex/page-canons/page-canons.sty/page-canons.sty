    \fi
    \pagecanon@ifeq{\pagecanon@margins}{symmetric}{%
      \newgeometry{inner=\the\pagecanon@innermargin,outer=\the\pagecanon@outermargin,
        top=\the\pagecanon@topmargin,bottom=\the\pagecanon@bottommargin,
