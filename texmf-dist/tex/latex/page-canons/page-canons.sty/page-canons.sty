  % \sidenotetext[num]{text}[voffset]
  \newcommand{\sidenotetext}[2][]{%
    \def\CM@tmp@num{#1}%
    \ifx\CM@tmp@num\@empty
      \edef\CM@tmp@num{\arabic{sidenote}}\fi
    \@ifnextchar[{%
      \CM@sidenote@place{\CM@tmp@num}{#2}%
    }{%
      \CM@sidenote@place{\CM@tmp@num}{#2}[0pt]%
    }}%
}
