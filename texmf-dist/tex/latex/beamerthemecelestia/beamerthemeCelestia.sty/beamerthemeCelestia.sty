\defbeamertemplate{frametitle}{clean}{%
  \setlength{\celestia@ft@bary}{\celestia@ftsep{1.5em}}%
  \addtolength{\celestia@ft@bary}{-0.425em}%
  \ifx\celestia@frametitlepadding\@empty
    \setlength{\celestia@ft@barx}{\dimexpr\celestia@ft@left@margin-0.5em\relax}%
  \else
    \setlength{\celestia@ft@barx}{\dimexpr\celestia@ft@left@margin-0.5em\relax}%
    \addtolength{\celestia@ft@barx}{\celestia@frametitlepadding}%
    \divide\celestia@ft@barx by 2%
  \fi
  \nointerlineskip%
  \begin{beamercolorbox}[wd=\paperwidth,
    leftskip=\dimexpr\celestia@ft@left@margin-0.5em,
    sep=\celestia@ftsep{1.5em}]{frametitle}
    {\usebeamerfont{frametitle}\color{emphasis}\begingroup\hypersetup{hidelinks}\insertframetitle\endgroup}%
    \ifx\insertframesubtitle\@empty\else%
      \par{\usebeamerfont{framesubtitle}\color{main!70}\insertframesubtitle}%
    \fi%
    \begin{tikzpicture}[remember picture, overlay]
      \coordinate (clean@bottom);
      \fill[emphasis]
        ([xshift=\celestia@ft@barx, yshift=-\celestia@ft@bary]current page.north west)
        rectangle
        ([xshift=\dimexpr\celestia@ft@barx+0.3em\relax, yshift=-0.5em]current page.north west |- clean@bottom);
    \end{tikzpicture}%
  \end{beamercolorbox}%
  \ifx\celestia@frametitlebottomskip\@empty
    \ifx\insertframesubtitle\@empty
      \vskip-1em%
    \else
      \vskip-0.5em%
    \fi
  \else
    \vskip\celestia@frametitlebottomskip%
  \fi
}

