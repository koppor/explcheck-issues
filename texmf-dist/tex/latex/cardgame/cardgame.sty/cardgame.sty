\NewDocumentCommand\ShowCard{ o }{
  \IfNoValueTF{#1}{
    \typeset_card:nnn{\clist_item:Nn\g_cards_clist{-1}}{}{}
  }{
    \typeset_card:onn{card_by_uid @ #1}{}{}
  }
}
\NewDocumentCommand\PrintCards{ O{} }{
  \print_cards:n{#1}
}
\NewDocumentCommand\ListCards{ O{} }{
  \list_cards:n{#1}
}
