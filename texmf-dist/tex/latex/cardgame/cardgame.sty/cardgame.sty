      \card:n{
        #1,
      }
    }{
      \card:n{
        #1,
        text={#3},
      }
    }
  }{
    \IfBlankTF{#3}{
      \card:n{
        #1,
        name={#2}
      }
    }{
      \card:n{
        #1,
        text={#3},
        name={#2}
      }
    }
  }
}

\NewDocumentCommand\DeclareCardType{O{} m m}{
  \IfBlankTF{#1}{
