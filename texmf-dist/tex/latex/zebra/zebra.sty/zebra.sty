          {
            \bool_set_true:N \l__zebra_emit_label_bool
            \prop_put:NVn \l__zebra_label_emitted_prop
              \l__zebra_note_target_tl { 1 }
          }
      }
    \group_begin:
      \bool_if:NF \l__zebra_unnumbered_bool
        {
