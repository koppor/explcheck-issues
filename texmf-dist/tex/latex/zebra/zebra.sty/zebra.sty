%% Numbered path.  Four cases:
%%   Case 1 — sbox reuse:   instance_key found → reuse, render
%%   Case 2 — stable key:   label found, stable_key in prop → suppress
%%   Case 3 — content sig:  sig in .aux data → suppress
%%   Case 4 — new note:     allocate, render
%% Case 1 also catches an unlabeled same-source-line same-body pair
%% (\todo{x}\todo{x}); the second is collapsed.  Two such notes are
%% indistinguishable at TeX level from a single note replayed by an
%% sbox/moving argument, so this collision is documented and resolved
%% by adding \label or splitting the line.
\cs_new_protected:Npn \__zebra_note_numbered:nnn #1#2#3
  {
    \bool_if:NT \l__zebra_draft_bool
      {
