            %% Only unlabeled current encounters may be suppressed by
            %% content signature; labeled encounters already have a
            %% strong identity via the stable key.  Suppress only if
            %% the stored instance key differs from the current one —
            %% same key means it is the original note, not a replay.
            \bool_if:NF \l_tmpa_bool
