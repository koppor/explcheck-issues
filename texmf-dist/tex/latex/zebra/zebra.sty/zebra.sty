        %% Case 1: sbox reuse (same \inputlineno)
        \tl_set:Nx \l__zebra_note_key_tl
          { \__zebra_instance_key:nnn {#1} {#2} {#3} }
        \prop_get:NVNTF \g__zebra_note_target_prop \l__zebra_note_key_tl
            \l__zebra_note_target_tl
          {
            \prop_get:NVN \g__zebra_note_display_prop \l__zebra_note_key_tl
              \l__zebra_note_display_tl
            \__zebra_render_note:nnn {#1} {#2} {#3}
