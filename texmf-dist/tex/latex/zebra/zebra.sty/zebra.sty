          \__zebra_if_package_loaded:nT { hyperref }
            { \tl_set:Nx \@currentHref { \l__zebra_note_target_tl } }
          \tl_set:Nx \l__zebra_note_ref_type_tl
            { \__zebra_capitalize_type:n {#1} }
          \__zebra_target:nn { \l__zebra_note_target_tl } {}
          \bool_if:NT \l__zebra_emit_label_bool
            { \exp_args:NV \__zebra_kernel_label:n \l__zebra_note_target_tl }
        }
      \__zebra_margin_note:nn
        {\textcolor{\l__zebra_note_color_tl}{%
          \bool_if:NF \l__zebra_unnumbered_bool
            { {\bfseries\l__zebra_note_display_tl}\kern1pt }%
          \__zebra_note_symbol:n {#1}}}
        {\textcolor{\l__zebra_note_color_tl}{%
          \__zebra_note_symbol:n {#1}%
          \bool_if:NF \l__zebra_unnumbered_bool
            { \kern1pt {\bfseries\l__zebra_note_display_tl} }}}%
