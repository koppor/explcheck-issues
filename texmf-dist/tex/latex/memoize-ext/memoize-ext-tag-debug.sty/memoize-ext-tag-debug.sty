\socket_new_plug:nnn {tagsupport/tikz/picture/init} {mmzx}
{
    \__mmzx_debug:n {Executing~plug~mmzx~in~socket~
      tagsupport/tikz/picture/init.}
  \bool_set_false:N \l__mmzx_ok_bool
  \legacy_if:nT {memoizing}
  {
    \__mmzx_debug:n {Arg~to~tagsupport/tikz/picture/init~is~#1.}
    \pgfkeyssavekeyfilterstateto\mmzx@temp@tagging@saved@filterstate
    \pgfkeysinstallkeyfilter{/pgf/key~filters/active~families~or~no~family}
      {{/pgf/key~filters/false}{/pgf/key~filters/false}}
    \pgfqkeysactivatesinglefamilyandfilteroptions{/tikz/tagging-setup}{/tikz}{#1}

    \__mmzx_debug:e { Restoring~filter~state:~\exp_not:V
      \mmzx@temp@tagging@saved@filterstate }
    \mmzx@temp@tagging@saved@filterstate
    \bool_if:NF \l__mmzx_ok_bool
    {
            \__mmzx_debug:n {
              No~plug~set~for~utilisation.~Trying~to~match~latex-lab~plug.
            }
      \xtoksapp\mmzContextExtra {
        tagging~plug=\__mmzx_socket_assigned_plug:n {tagsupport/tikz/picture/begin},
      }
      \str_case_e:nn
      {\__mmzx_socket_assigned_plug:n {tagsupport/tikz/picture/begin}}
      {
        {alt} {
          \exp_args:Ne \mmzset{
            alt = \exp_not:V \l__tikz_tagging_alt_tl,
          }
            \__mmzx_debug:n {Using~alt~plug.}
        }
        {actualtext} {
          \exp_args:Ne \mmzset{
            actualtext = \exp_not:V \l__tikz_tagging_actualtext_tl,
          }
            \__mmzx_debug:n {Using~actualtext~plug.}
        }
        {artifact} {
          \mmzset{artifact,}
            \__mmzx_debug:n {Using~artifact~plug.}
        }
        {text} {
          \bool_set_false:N \l__mmzx_ok_bool
            \__mmzx_debug:e {Found~unsupported~
              text~
              {tagsupport/tikz/picture/begin}~plug.}
          \PackageWarning{memoize-ext}{Unsupported~tag~config~for~tikz~picture.~
            Please~use~alt,~actualtext,~artifact~or~another supported~plug.~
            Note~that~text~(the~latex-lab~default)~is~NOT~supported.~
            Aborting~memoization~and~marking~code~unmemoizable.
          }
          \mmzUnmemoizable
        }
      }
    }
  }
  \bool_if:NT \l__mmzx_ok_bool
  {
    % ^^A uses the currently assigned plugs for the before/after sockets
    \__mmzx_tag_socket_plug_record:
    \__mmzx_debug:n {Disabling~tagging~for~current~tikz~picture~during~
      current~run.}
    \socket_assign_plug:nn {tagsupport/tikz/picture/begin} {noop}
    \socket_assign_plug:nn {tagsupport/tikz/picture/end} {noop}
    \socket_assign_plug:nn {tagsupport/tikz/picture/text/begin} {noop}
    \socket_assign_plug:nn {tagsupport/tikz/picture/text/end} {noop}
  }
}
\hook_gput_code:nnn {cmd/mmzAbort/after} {.}
{
  \legacy_if:nT {memoizing} {
    \PackageWarning{memoize-ext}{
      Memoization~has~been~aborted.~If~something~like~a~reference~needs~
      resolving,~just~compile~again.~If~the~content~is~unmemoizable~--~
      e.g.~contains~remember~picture,~a~breakable~tcolorbox~or~suchlike,~
      you~**must**~mark~the~content~unmemoizable~or~the~tagging~will~be~
      incorrect.~You~may~do~this~automatically~or~manually.~Aborted~
    }
  }
}
