\socket_new_plug:nnn {tagsupport/memoize/include/extern/before} {mmzx/alt}
{
    \__mmzx_debug:n {Executing~plug~mmzx/alt~in~socket~
      tagsupport/memoize/include/extern/before.}
  \mode_if_vertical:T
  {
    \if@inlabel
      \mode_leave_vertical:
    \else
      \tag_socket_use:n {para/begin}
    \fi
  }
  \tag_mc_end_push:
  \tl_set:No \l__mmzx_toks_tl {\the\mmzxtagtoks}
  \tag_struct_begin:n
  {
    tag=Figure,
    alt=\l__mmzx_toks_tl,
  }
  \tag_mc_begin:n {tag=Figure}
  \cs_new:cpe {mmzx@tag@tikz@mark@pos@\int_to_arabic:n {\g__mmzx_tagpic_int}}
  {
    \__mmzx_pgftikz_tag_bbox:ennn {mmzx-id\int_to_arabic:n {\g__mmzx_tagpic_int}}
    {#1}{#2}{#3}
  }
    \cs_log:c {mmzx@tag@tikz@mark@pos@\int_to_arabic:n
      {\g__mmzx_tagpic_int}}
  \tag_struct_gput:ene
  {\tag_get:n {struct_num}}
  {attribute}
  {
    /O /Layout /BBox~
    [
      \use:c
      {mmzx@tag@tikz@mark@pos@\int_to_arabic:n {\g__mmzx_tagpic_int}}
    ]
  }
    \__mmzx_debug:e {Recording~xpos,~
      ypos~of~mmxc-id\int_to_arabic:n {\g__mmzx_tagpic_int}.}
  \tex_savepos:D
  \__mmzx_property_record_orig:ee
    {mmzx-id\int_to_arabic:n {\g__mmzx_tagpic_int}}
    {xpos,ypos}
  \tex_savepos:D
}
