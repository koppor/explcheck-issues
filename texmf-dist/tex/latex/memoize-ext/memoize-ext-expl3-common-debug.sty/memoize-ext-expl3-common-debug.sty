%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\bool_new:N \l__mmzx_expl_bool
\cs_new_protected_nopar:Npn \__mmzx_restore_ccmemo_input: {}
\cs_new_protected_nopar:Npn \__mmzx_saved_mmzxExplAtBegin: {}
\cs_new_protected_nopar:Npn \__mmzx_saved_mmzxExplAtEnd: {}
\hook_gput_code:nnn {begindocument/end}{.}
{
  \bool_set_false:N \l__mmzx_expl_bool
}
\hook_gput_code:nnn {begindocument/end}{.}
{
    \__mmzx_debug:n {Tracking~expl3~syntax~changes.}
  \bool_set_false:N \l__mmzx_expl_bool
  \hook_gput_code:nnn {cmd/ExplSyntaxOn/before} { . }
  {
    \bool_if:NF \l__mmzx_expl_bool
    {
      \bool_set_true:N \l__mmzx_expl_bool
      \ifmmz@direct@ccmemo@input
        \relax
      \else
        \cs_set_protected_nopar:Npn \__mmzx_restore_ccmemo_input:
        {
          \mmz@direct@ccmemo@inputfalse
        }
      \fi
      \mmz@direct@ccmemo@inputtrue
      \cs_set_eq:NN \__mmzx_saved_mmzxExplAtBegin: \mmzxExplAtBegin
      \cs_set_eq:NN \__mmzx_saved_mmzxExplAtEnd: \mmzxExplAtEnd
      \__mmzx_expl_at_start:
    }
  }
  \hook_gput_code:nnn {cmd/ExplSyntaxOn/after} { . }
  {
    \hook_gput_code:nnn {cmd/ExplSyntaxOff/before} { . }
    {
      \bool_set_false:N \l__mmzx_expl_bool
      \cs_set_eq:NN \mmzxExplAtBegin \__mmzx_saved_mmzxExplAtBegin:
      \cs_set_eq:NN \mmzxExplAtEnd \__mmzx_saved_mmzxExplAtEnd:
      \__mmzx_restore_ccmemo_input:
    }
  }
}
\cs_new_eq:NN  \__mmzx_cctab_end: \cctab_end:
\cs_new_protected_nopar:Npn \__mmzx_expl_at_begin:
{
  \cctab_begin:N \c__mmzx_expl_at_cctab
}
\cs_new_protected_nopar:Npn \__mmzx_nexpl_at_begin:
{
  \cctab_begin:N \c__mmzx_nexpl_at_cctab
}
\cs_new_nopar:Npn \__mmzx_expl_at_start:
{
  \cs_set_nopar:Npn \mmzxExplAtBegin {__mmzx_expl_at_begin:}
  \cs_set_nopar:Npn \mmzxExplAtEnd {__mmzx_cctab_end:}
}
\cs_new_nopar:Npn \__mmzx_nexpl_at_start:
{
  \cs_set_nopar:Npn \mmzxExplAtBegin {__mmzx_nexpl_at_begin:}
  \cs_set_nopar:Npn \mmzxExplAtEnd {__mmzx_cctab_end:}
}
\cs_new_protected_nopar:Npn \__mmzx_cctab_stop:
{
  \cs_set_nopar:Npn \mmzxExplAtBegin {relax}
  \cs_set_nopar:Npn \mmzxExplAtEnd {relax}
}
\appto\mmzAtBeginMemoization{
    \__mmzx_debug:n {Appending~expl~begin~to~ccmemo~at~end~
      \string\mmzAtBeginMemoization.}
  \xtoksapp\mmzCCMemo
  {
    \exp_not:N \csname \mmzxExplAtBegin \exp_not:N \endcsname
  }
    \exp_args:No \__mmzx_debug:n {\the\mmzCCMemo}
}
    \cs_log:N \mmzAtBeginMemoization
\preto\mmzAtEndMemoization{
    \__mmzx_debug:n {Appending~expl~end~to~ccmemo~at~start~
      \string\mmzAtEndMemoization.}
  \xtoksapp\mmzCCMemo
  {
    \exp_not:N \csname \mmzxExplAtEnd \exp_not:N \endcsname
  }
}
    \cs_log:N \mmzAtEndMemoization
\hook_gput_code:nnn { begindocument/end } {mmzx}
{
    \__mmzx_cctab_stop:
}
