\bool_new:N \l__mmzx_replicating_bool
\bool_set_false:N \l__mmzx_replicating_bool
\prg_new_conditional:Npnn \__mmzx_if_replicating: {p,T,TF,F}
{
  \if_bool:N \l__mmzx_replicating_bool
    \__mmzx_debug:n {Replicating~true.}
    \prg_return_true:
  \else:
    \__mmzx_debug:n {Replicating~false.}
    \prg_return_false:
  \fi:
}
\cs_new:Npn \AdviceRunIfNotReplicating
{
  \__mmzx_if_replicating:F
  {
    \__mmzx_debug:n {Not~replicating,~so~proceeding.}
    \ifmemoizing \AdviceRuntrue \fi
  }
}
\mmzset{
  auto/run~if~not~replicating/.style = {
    run~conditions={\AdviceRunIfNotReplicating},
  },
}
\cctab_const:Nn \c__mmzx_expl_at_cctab {
  \cctab_select:N \c_code_cctab
  \makeatletter
}
\cctab_const:Nn \c__mmzx_nexpl_at_cctab {
  \cctab_select:N \c_code_cctab
  \makeatletter
  \int_set:Nn \tex_endlinechar:D { 13 }
  \char_set_catcode_space:n      { 9 }
  \char_set_catcode_space:n      { 32 }
  \char_set_catcode_active:n     { 126 } % tilde
}
