\hook_gput_code:nnn {class/ltx-talk/after}{.}
{
    \__mmzx_debug:n {Enabling~ltx-talk~support.}
  \mmzset{
    per~overlay/.code={},
    talk~mode~to~prefix/.style={
      prefix=\mmz@prefix@dir\mmz@prefix@name\l__mmzx_talk_mode_str -,
    },
  }
  \seq_new:N \g__mmzx_talk_opacity_seq
  \seq_new:N \g__mmzx_talk_saved_opacity_seq
  \tl_new:N \l__mmzx_talk_opacity_tl

  \cs_new_eq:NN \g__mmzx_talk_frame_int \c@frame
  \cs_new_eq:NN \g__mmzx_talk_slide_int \c@slide
  \cs_new_eq:NN \g__mmzx_talk_pauses_int \c@pauses
  \cs_new_eq:NN \l__mmzx_talk_mode_str \l__talk_mode_str
  \cs_generate_variant:Nn \opacity_select:n {V}
  \seq_gpush:Nn \g__mmzx_talk_opacity_seq {1}
  \cs_new_protected_nopar:Npn \__mmzx_talk_opacity_save:
  {
    \seq_gset_eq:NN \g__mmzx_talk_opacity_saved_seq \g__mmzx_talk_opacity_seq
    \seq_get:NN \g__mmzx_talk_opacity_seq \l__mmzx_talk_opacity_tl
    \exp_args:NV \tl_if_eq:NNTF \l__mmzx_talk_opacity_tl \q_no_value
    {
      \seq_gpush:Nn \g__mmzx_talk_opacity_saved_seq {1}
      \opacity_select:n {1}
    } {
      \seq_gpush:NV \g__mmzx_talk_opacity_saved_seq \l__mmzx_talk_opacity_tl
      \opacity_select:V \l__mmzx_talk_opacity_tl
    }
  }
  \cs_new_protected_nopar:Npn \__mmzx_talk_opacity_restore:
  {
    \seq_gpop:NN \g__mmzx_talk_opacity_saved_seq \l__mmzx_talk_opacity_tl
    \opacity_select:V \l__mmzx_talk_opacity_tl
    \seq_gset_eq:NN \g__mmzx_talk_opacity_seq \g__mmzx_talk_opacity_saved_seq
  }
  \long\def\mmzSingleExternDriver#1{
    \xtoksapp\mmzCCMemo{\mmz@maybe@quitvmode}
    \setbox\mmz@box\mmz@capture{
      \__mmzx_talk_opacity_save:
      #1
      \__mmzx_talk_opacity_restore:
    }
    \mmzExternalizeBox\mmz@box\mmz@temptoks
    \xtoksapp\mmzCCMemo{\the\mmz@temptoks}
    \mmz@maybe@quitvmode\box\mmz@box
  }
  \hook_gset_rule:nnnn {begindocument} {ltx-talk} {<} {.}
  \hook_gput_code_with_args:nnn {cmd/opacity_select:n/before} {.}
  {
    \seq_gpush:Nn \g__mmzx_talk_opacity_seq {#1}
  }
  \hook_gput_code:nnn {cmd/opacity_end:/after}{.}
  {
    \__mmzx_debug:n{Opacity~after}
    \seq_gpop:NN \g__mmzx_talk_opacity_seq \l_tmpa_tl
    \seq_log:N \g__mmzx_talk_opacity_seq
  }
  \mmzset{
    at~begin~memoization={
      \socket_use:n {mmzx/talk/memoization/begin}
    },
    at~end~memoization={
      \socket_use:n {mmzx/talk/memoization/end}
    },
    per~overlay/.style={
      /mmz/context={
        overlay=\csname theslide\endcsname,
        pauses=\ifmemoizing
          \mmzxTalkPauses
        \else
          \expandafter\the\csname c@pauses\endcsname
        \fi
      },
      /utils/exec={
        \str_if_eq:eeF {peroverlay}
        {\__mmzx_socket_assigned_plug:n {mmzx/talk/memoization/begin}}
        {
          \socket_assign_plug:nn {mmzx/talk/memoization/begin}{peroverlay}
          \socket_assign_plug:nn {mmzx/talk/memoization/end}{peroverlay}
          \legacy_if:nT {memoizing} {
            \socket_use:n {mmzx/talk/memoization/begin}
          }
        }
      },
      /mmz/per~overlay/.code={},
    },
  }
  \socket_new:nn {mmzx/talk/memoization/begin}{0}
  \socket_new:nn {mmzx/talk/memoization/end}{0}
  \socket_new_plug:nnn {mmzx/talk/memoization/begin}{peroverlay}
  {
    \__mmzx_debug:n {Executing~plug~peroverlay~in~socket~
      mmzx/talk/memoization/begin.}
    \xdef\mmzxTalkPauses{
      \int_to_arabic:n {\g__mmzx_talk_pauses_int}
    }
    \xtoksapp\mmzCMemo{
      \noexpand\mmzxSetTalkOverlays{\mmzxTalkPauses}{
        \int_to_arabic:n {\g__mmzx_talk_slide_int}
      }
    }
    \gtoksapp\mmzCCMemo{
      \only<all:\mmzxTalkOverlays>{}
    }
    \seq_get:NNTF \g__mmzx_talk_opacity_seq \l__mmzx_opacity_tl
    {
      \fp_gset:NV \l__mmzx_tmpa_fp \l__mmzx_opacity_tl
    } {
      \fp_gset:Nn \l__mmzx_tmpa_fp {1}
    }
    \xtoksapp\mmzContextExtra{
      opacity=\fp_to_decimal:N \l__mmzx_tmpa_fp
    }
  }
  \socket_new_plug:nnn {mmzx/talk/memoization/end}{peroverlay}
  {
    \__mmzx_debug:n {Executing~plug~peroverlay~in~socket~
      mmzx/talk/memoization/end.}
    \xtoksapp\mmzCCMemo{
      \exp_not:N \setcounter{pauses}
      {\int_to_arabic:n {\g__mmzx_talk_pauses_int}}
    }
  }
  \cs_new_nopar:Npn \mmzxSetTalkOverlays#1#2{
    \__mmzx_debug:e {Executing~\cs_to_str:N \mmzxSetTalkOverlays}
    \int_compare:nNnTF {\g__mmzx_talk_pauses_int} = {#1}
    {
      \gdef\mmzxTalkOverlays{#2}
      \int_compare:nNnTF {\g__mmzx_talk_slide_int} < {#2}
      {
        \bool_set_true:N \l__mmzx_tmpa_bool
      }{
        \bool_set_false:N \l__mmzx_tmpa_bool
      }
    }{
      \bool_set_true:N \l__mmzx_tmpa_bool
    }
    \bool_if:NT \l__mmzx_tmpa_bool
    {
      \bool_gset_true:N \g__talk_slide_continue_bool
      \appto\mmzAtBeginMemoization{
        \gtoksapp\mmzCMemo{\mmzxSetTalkOverlays{#1}{#2}}
      }
    }
  }
}
