    }
}

\NewDocumentCommand \hawkdrawset { m } {
    \clist_clear:N \l__hawkdraw_keys_unprocessed_clist
    \keys_set_known:nnnN { hawkdraw / path } {#1} { hawkdraw / path }
        \l__hawkdraw_keys_unprocessed_clist
    \keys_set:nV { hawkdraw }
        \l__hawkdraw_keys_unprocessed_clist
}

\NewDocumentEnvironment { hawkdraw } { O{} } {
    % ensure that relevant characters are not active
    \seq_clear:N \l__hawkdraw_chars_active_seq
    \int_step_inline:nnn { 32 } { 127 } {
        \int_compare:nNnT { \char_value_catcode:n {##1} } = { 13 } {
            \seq_put_right:Nn \l__hawkdraw_chars_active_seq {##1}
        }
    }
    \seq_if_empty:NF \l__hawkdraw_chars_active_seq {
        \keys_set:nn { hawkdraw / path / node } { rescan }
    }
    \cctab_select:N \c_hawkdraw_environment_cctab
    \int_gincr:N \g_hawkdraw_picture_id_int
    \cs_set_eq:NN \path \hawkdraw_path:w
    \cs_set_eq:NN \getpoint \hawkdraw_point_parse:n
    \cs_set_protected:Npn \stroke { \path [ stroke ] }
    \cs_set_protected:Npn \fill { \path [ fill ] }
    \cs_set_protected:Npn \clip { \path [ clip ] }
    \cs_set_protected:Npn \node { \path ( 0pt , 0pt ) node }
    \cs_set_protected:Npn \point { \path ( 0pt , 0pt ) point }
    \cs_set_protected:Npn \map { \path ( 0pt , 0pt ) map }
    \NewExpandableDocumentCommand \getpointx { m } {
        \hawkdraw_tuple_use_i:n { \hawkdraw_point_parse:n {##1} }
    }
    \NewExpandableDocumentCommand \getpointy { m } {
        \hawkdraw_tuple_use_ii:n { \hawkdraw_point_parse:n {##1} }
    }
    \NewExpandableDocumentCommand \getintersectionlines { m m m m } {
        \draw_point_intersect_lines:nnnn
            { \hawkdraw_point_parse:n {##1} } { \hawkdraw_point_parse:n {##2} }
            { \hawkdraw_point_parse:n {##3} } { \hawkdraw_point_parse:n {##4} }
    }
    \NewExpandableDocumentCommand \getintersectioncircles { O{ 1 } m m m m } {
        \draw_point_intersect_circles:nnnnn
            { \hawkdraw_point_parse:n {##2} } {##3}
            { \hawkdraw_point_parse:n {##4} } {##5}
            {##1}
    }
    \NewExpandableDocumentCommand \getintersectionlinecircle { O{ 1 } m m m m } {
        \draw_point_intersect_line_circle:nnnnn
            { \hawkdraw_point_parse:n {##2} } { \hawkdraw_point_parse:n {##3} }
            { \hawkdraw_point_parse:n {##4} } {##5}
            {##1}
    }
    \NewExpandableDocumentCommand \getfirstpoint { } {
        \fp_use:N \g_hawkdraw_path_point_first_fp
    }
    \NewExpandableDocumentCommand \getlastpoint { } {
        \fp_use:N \g_hawkdraw_path_point_last_fp
    }
    \NewExpandableDocumentCommand \getfirstslope { } {
        \fp_use:N \g_hawkdraw_path_slope_first_fp
    }
    \NewExpandableDocumentCommand \getlastslope { } {
        \fp_use:N \g_hawkdraw_path_slope_last_fp
    }
    \NewDocumentCommand \getpathlength { m } {
        \hawkdraw_path_get_length:
        \dim_set:Nn #1 {
            \fp_to_dim:N \g_hawkdraw_path_length_fp
        }
    }
    \NewDocumentEnvironment { scope } { O{} } {
        \draw_scope_begin:
            \clist_clear:N \l__hawkdraw_keys_unprocessed_clist
            \keys_set_known:nnN { hawkdraw / scope } {##1}
                \l__hawkdraw_keys_unprocessed_clist
            \keys_set_known:nVN { hawkdraw / tag } \l__hawkdraw_keys_unprocessed_clist
                \l__hawkdraw_keys_unprocessed_clist
            \keys_set_exclude_groups:nnV { hawkdraw / path } { tag }
                \l__hawkdraw_keys_unprocessed_clist
            \tl_if_empty:NF \l_hawkdraw_scope_layer_tl {
                \draw_layer_begin:V \l_hawkdraw_scope_layer_tl
            }
    } {
            \tl_if_empty:NF \l_hawkdraw_scope_layer_tl {
                \draw_layer_end:
            }
        \draw_scope_end:
    }
    \fp_set:Nn \l_hawkdraw_picture_baseline_fp { nan }
    \mode_leave_vertical:
    \tag_socket_use:nn { hawkdraw / picture / init } {#1}
    \tag_socket_use:n { hawkdraw / picture / begin }
    \tag_suspend:n { hawkdraw / picture }
    \nullfont
    \draw_begin:
        \clist_clear:N \l__hawkdraw_keys_unprocessed_clist
        \keys_set_known:nnN { hawkdraw / picture } {#1}
            \l__hawkdraw_keys_unprocessed_clist
        \keys_set_exclude_groups:nnV { hawkdraw / path } { tag }
            \l__hawkdraw_keys_unprocessed_clist
        \fp_if_nan:nF { \l_hawkdraw_picture_baseline_fp } {
            \draw_set_baseline:n {
                \fp_to_dim:n { \l_hawkdraw_picture_baseline_fp }
            }
        }
        \int_compare:nNnT { \clist_count:N \l_hawkdraw_picture_bb_clist } = { 4 } {
            \draw_path_rectangle_corners:nn {
                (
                    \clist_item:Nn \l_hawkdraw_picture_bb_clist { 1 }
                ,
                    \clist_item:Nn \l_hawkdraw_picture_bb_clist { 2 }
                )
            } {
                (
                    \clist_item:Nn \l_hawkdraw_picture_bb_clist { 3 }
                ,
                    \clist_item:Nn \l_hawkdraw_picture_bb_clist { 4 }
                )
            }
            \draw_path_replace_bb:
            \bool_set_false:N \l_draw_bb_update_bool
        }
} {
    \draw_end:
    \tag_resume:n { hawkdraw / picture }
    \tag_socket_use:nn { hawkdraw / picture / end } {
        \hawkdraw_tag_bb_attribute_use:
    }
}

