\keys_define:nn { hawkdraw / tag } {
    mode                    .code:n         = {
        \tl_set:Ne \l_tag_graphic_mode_tl {#1}
    } ,
    alt                     .code:n         = {
        \pdf_purify:nN {#1} \l_hawkdraw_tag_alt_tl
        \tl_set:Nn \l_hawkdraw_tag_mode_tl { alt }
        \tl_set:Nn \l_hawkdraw_tag_role_tl { Figure }
    } ,
    artifact                .code:n         = {
        \tl_set:Nn \l_hawkdraw_tag_mode_tl { artifact }
    } ,
    actualtext              .code:n         = {
        \pdf_purify:nN {#1} \l_hawkdraw_tag_actualtext_tl
        \tl_set:Nn \l_hawkdraw_tag_mode_tl { actualtext }
        \tl_set:Nn \l_hawkdraw_tag_role_tl { Span }
    } ,
    text                    .code:n         = {
        \tl_set:Nn \l_hawkdraw_tag_mode_tl { text }
    } ,
    off                    .code:n         = {
        \tl_set:Nn \l_hawkdraw_tag_mode_tl { off }
    } ,
    tagging-setup           .code:n         = {
        \keys_set:nn { hawkdraw / tag } {#1}
    } ,
    tag                     .code:n         = {
        \str_case:nnF {#1} {
            { artifact } {
                \tl_set:Nn \l_hawkdraw_tag_mode_tl { artifact }
            }
            { false } {
                \tag_suspend:n { hawkdraw / picture }
            }
        } {
            \pdf_purify:nN {#1} \l_hawkdraw_tag_role_tl
            \tl_set:Nn \l_hawkdraw_tag_mode_tl { alt }
        }
    } ,
}

\keys_define:nn { hawkdraw / path } {
    mode                    .groups:n       = { tag } ,
    alt                     .groups:n       = { tag } ,
    artifact                .groups:n       = { tag } ,
