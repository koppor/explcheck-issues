        % \pgftext[at={\pgfpoint{0em}{-4em}}] {this case = \thiscase}
        % Extract coordinates to main registers, \pgf@x and \pgf@y
        \pgf@process{\pgfpointintersectionsolution{1}}
		\endpgfinterruptboundingbox
	}

	% Draw it
	\backgroundpath{
		\pgfpathmoveto{\northeast}
		\pgfpathlineto{\southwest \pgf@y=-\pgf@y}
		\pgfpathlineto{\southwest}
		\pgfpathlineto{\northeast \pgf@y=-\pgf@y}
		\pgfpathclose
		\pgfsetroundjoin
		\pgfsetroundcap
	}
}


