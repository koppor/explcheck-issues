    \ifpc@lopt@disable\else
      \hspace*{0pt}%
      %\pc@create@lpc% ????????
      % typeset text annotation (see: PDF Reference)
      \xdef\pc@zref@PDFOBJID{\pc@get@PDFOBJID{\pc@lopt@replyto}}
