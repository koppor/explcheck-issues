        {
         \str_if_eq:eeTF{##1}{A}
          {
            \xdef\pc@collect@PDFOBJID{\pc@collect@PDFOBJID,A}
          }
          {
           \str_if_eq:eeF{##1}{S}
            {
              \pdfdict_put:nnn {l__pdfcomment_text_dict}  {IRT}{##1}
              \vbox
              {\tagpdfparaOff
                \hsize=0pt
                \noindent
                \vspace{\pc@lopt@voffset}
                \hbox to 0pt
                {
                  \vsize=0pt
                  \hskip\pc@lopt@hoffset
                  \UseTaggingSocket{pdfcomment/annotbox}
                   {l__pdfcomment_text_dict}
                   {
                    \pdfannot_box:nnne
                      {0pt}
                      {\normalbaselineskip}
                      {0pt}
                      {
                        \pdfdict_use:n{l__pdfcomment_text_dict}
                        \pdfdict_use:n {l__pdfcomment_markup_dict}
                      }
                   }
                  \__pdfcomment_collect_objid:
                  \hss
                }
              }
            }
          }
        }
        \__pdfcomment_save_objid:
    \fi
  \fi
  \group_end:
}
