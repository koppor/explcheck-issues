\newenvironment{pdfsidelinecomment}[2][]
 {
  \ifhmode\unskip\fi
  \ifvmode\leavevmode\fi
  \gdef\pc@collect@PDFOBJID{S}
  \keys_set:nn{pdfcomment}{#1}
  \def\pc@lopt@subtype{/Line}
  \def\pc@lopt@comment{#2}
