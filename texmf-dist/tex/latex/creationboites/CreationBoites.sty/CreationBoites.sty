  PoliceSousTitre=\renewcommand\policesoustitreboite{#1},%
  Marge=\renewcommand\margeboite{#1},%
  TailleIcone=\renewcommand\tailleiconeboite{#1},%
  CouleurSousTitre=\renewcommand\couleursoustitreboite{#1},%
