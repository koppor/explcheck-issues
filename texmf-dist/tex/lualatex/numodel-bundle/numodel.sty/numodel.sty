        (#1) ~ \exp_not:n{at} ~
        ( \use:c{#1 gridx} , ~ \use:c{#1 gridy} ) ~
        { \exp_not:N $ \exp_not:V \l__numodel_tmp_tl \exp_not:N $ } ;
      }
