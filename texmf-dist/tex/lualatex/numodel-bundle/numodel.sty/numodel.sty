    \__numodel_emit_valve_extras:n {#1}
  }

\cs_new_protected:Npn \__numodel_emit_valve_extras:n #1
  {
    \prop_get:NnNT \l__numodel_valve_extras_prop {#1} \l__numodel_scratch_tl
      {
